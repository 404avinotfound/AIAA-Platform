# URL of the backend API (see backend/.env.example)
# Local dev: http://localhost:5000/api
# Production: your Render backend URL, e.g. https://aiaa-backend.onrender.com/api
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Must match RAZORPAY_KEY_ID in backend/.env (publishable key, safe for the browser)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
