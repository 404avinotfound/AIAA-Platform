# ====== SERVER ======
PORT=5000
NODE_ENV=development
# Local dev: http://localhost:3000
# Production: your Vercel URL(s), comma-separated if you need more than one
# (e.g. production domain + a specific preview domain):
# CLIENT_URL=https://aiaa.vercel.app,https://aiaa-platform-git-main-you.vercel.app
CLIENT_URL=http://localhost:3000

# ====== DATABASE ======
# Get a free cluster at https://www.mongodb.com/cloud/atlas
# IMPORTANT: never commit real credentials here — this file is just a template.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-host>/<db-name>?retryWrites=true&w=majority

# ====== AUTH ======
JWT_SECRET=replace_this_with_a_long_random_string
JWT_REFRESH_SECRET=replace_this_with_another_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ====== RAZORPAY (membership payments) ======
# Get test keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# ====== EMAIL (confirmations, OTP) ======
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="AIAA <no-reply@aiaa.org.in>"

# ====== GOVERNMENT JOBS SYNC ======
NCS_API_URL=https://betacloud.ncs.gov.in/api/v1/job-posts/search
JOB_SYNC_CRON=0 */6 * * *

# ====== FILE STORAGE ======
# Get free credentials at https://cloudinary.com
# Required in production on Render: Render's filesystem is ephemeral, so
# without these, uploaded profile photos / membership documents are lost on
# every restart or redeploy. Safe to leave blank for local development,
# where files are written to backend/uploads/ instead.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ====== ADMIN SEED ======
ADMIN_EMAIL=admin@aiaa.org.in
ADMIN_PASSWORD=admin@123
